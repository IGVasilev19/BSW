@using WarehouseManagementSystem.Models
@{
    ViewData["Title"] = "Sign In";
}
@model SignInViewModel

<div class="w-full h-full flex items-center justify-center bg-gray-100">
    <div class="w-[90%] h-[90%] rounded-3xl bg-white flex drop-shadow-2xl">
        <form asp-action="EmployeeSignIn" asp-controller="Access" method="post" class="w-full h-full flex flex-col items-center justify-center gap-5">
            <p class="select-none text-6xl font-bold text-[#2C3E50] tracking-widest font-poppins">SIGN IN</p>
            <div class="w-full flex flex-col px-5">
                <p class="text-[#2C3E50] text-xl font-poppins font-light">Email Address*</p>
                <input asp-for="Email" class="border-[#76b5c5] border-2 rounded-lg h-[60px] focus:outline-none focus:ring-0 px-4 py-2 caret-[#76b5c5b4] text-[#2C3E50]" />
            </div>
            <div class="w-full flex flex-col px-5">
                <p class="text-[#2C3E50] text-xl font-poppins font-light">Password*</p>
                <input asp-for="Password" type="password" class="border-[#76b5c5] border-2 rounded-lg h-[60px] focus:outline-none focus:ring-0 px-4 py-2 caret-[#76b5c5b4] text-[#2C3E50]" />
            </div>
            <button type="submit" class="w-1/3 h-[60px] bg-[#76b5c5] flex items-center justify-center rounded gap-3 transition-all duration-300 hover:scale-[1.05]">
                <p class="text-white tracking-wide font-poppins text-3xl p-0 m-0">SING IN</p>
            </button>
        </form>
        <img src="../images/sign-in.svg"/>
    </div>
</div>