@{
    ViewData["Title"] = "Sign Up";
}

<div class="w-full h-full flex items-center">
    <div class="w-full h-full flex flex-col items-center justify-center">
        <div class="w-full h-[100px] flex items-center px-5">
            <div class="bg-[url('../images/paintbrush.svg')] bg-center bg-contain bg-no-repeat w-full h-full flex items-center justify-center">
                <p class="text-6xl font-bold text-[#2C3E50] tracking-widest font-poppins">JOIN US TODAY</p>
            </div>
            <div class="w-[150px] h-0 border-2 border-[#76b5c577]">
            </div>
        </div>
        <img src="../images/doodle.svg" class="w-auto h-auto"/>
        <div class="flex flex-col justify-center gap-0 px-5">
            <p class="text-[#2C3E50] font-semibold text-lg font-poppins">We simplify operations in order to improve accuracy and growth. From inventory tracking to workflow optimization, our platform turns complexity into seamless efficiency.<p class="text-[#2C3E50] font-bold font-poppins text-2xl">Stay ahead with BSW</p></p>
        </div>
    </div>
    <div class="h-[900px] border-2 border-[#76b5c577]">
    </div>    
    <div class="flip-container w-full h-full perspective-1000 flex flex-col justify-center gap-5 px-5">
        <div id="flip-card" class="relative w-full h-full duration-700 transform-style-preserve-3d transition-transform ease-in-out">
            <div class="absolute w-full h-full backface-hidden flex flex-col gap-5 justify-center">
                <div class="flex flex-col">
                    <div class="flex flex-col justify-start">
                        <p class="text-6xl font-bold text-[#2C3E50] tracking-widest font-poppins">SIGN UP</p>
                        <div class="w-[140px] h-0 border-4 border-[#76b5c5]">
                        </div>
                    </div>
                </div>
                <div class="w-full flex justify-center gap-5">
                    <div class="w-full flex flex-col">
                        <p class="text-[#2C3E50] text-xl font-poppins font-light">Full Name*</p>
                        <input class="border-[#76b5c5] border-2 rounded-lg h-[60px] focus:outline-none focus:ring-0 px-4 py-2 caret-[#76b5c5b4] text-[#2C3E50]"/>
                    </div>
                    <div class="w-full flex flex-col">
                        <p class="text-[#2C3E50] text-xl font-poppins font-light">Phone Number*</p>
                        <input class="border-[#76b5c5] border-2 rounded-lg h-[60px] focus:outline-none focus:ring-0 px-4 py-2 caret-[#76b5c5b4] text-[#2C3E50]"/>
                    </div>
                </div>
                <div class="w-full flex flex-col">
                    <p class="text-[#2C3E50] text-xl font-poppins font-light">Email Address*</p>
                    <input class="border-[#76b5c5] border-2 rounded-lg h-[60px] focus:outline-none focus:ring-0 px-4 py-2 caret-[#76b5c5b4] text-[#2C3E50]"/>
                </div>
                <div class="w-full flex justify-center gap-5">
                    <div class="w-full flex flex-col">
                        <p class="text-[#2C3E50] text-xl font-poppins font-light">Password*</p>
                        <input class="border-[#76b5c5] border-2 rounded-lg h-[60px] focus:outline-none focus:ring-0 px-4 py-2 caret-[#76b5c5b4] text-[#2C3E50]"/>
                    </div>
                    <div class="w-full flex flex-col">
                        <p class="text-[#2C3E50] text-xl font-poppins font-light">Confirm Password*</p>
                        <input class="border-[#76b5c5] border-2 rounded-lg h-[60px] focus:outline-none focus:ring-0 px-4 py-2 caret-[#76b5c5b4] text-[#2C3E50]"/>
                    </div>
                </div>
                <div class="w-full flex flex-col">
                    <p class="text-[#2C3E50] text-xl font-poppins font-light">Warehouse Name*</p>
                    <input class="border-[#76b5c5] border-2 rounded-lg h-[60px] focus:outline-none px-4 py-2 caret-[#76b5c5b4] text-[#2C3E50] focus:ring-0"/>
                </div>
                <div class="group w-full flex justify-center">
                    <button id="next-button" onclick="flipCardNext()" class="w-1/3 h-[60px] bg-[#76b5c5] flex items-center justify-center rounded gap-3 transition-all duration-300 hover:scale-[1.05]">
                        <p class="text-white tracking-wide font-poppins text-3xl m-0">Next</p>
                        <img id="arrow2Icon" src="../images/Arrow 2.svg" class="h-[25px]"/>
                    </button>
                </div>
            </div>
            <div class="absolute w-full h-full rotate-y-180 backface-hidden flex flex-col gap-5 justify-center">
                <div class="flex flex-col">
                    <div class="flex flex-col justify-start">
                        <p class="text-6xl font-bold text-[#2C3E50] tracking-widest font-poppins">SIGN UP</p>
                        <div class="w-[140px] h-0 border-4 border-[#76b5c5]">
                        </div>
                    </div>
                </div>
                <div class="w-full flex flex-col">
                    <p class="text-[#2C3E50] text-xl font-poppins font-light">Country*</p>
                    <input class="border-[#76b5c5] border-2 rounded-lg h-[60px] focus:outline-none focus:ring-0 px-4 py-2 caret-[#76b5c5b4] text-[#2C3E50]"/>
                </div>
                <div class="w-full flex flex-col">
                    <p class="text-[#2C3E50] text-xl font-poppins font-light">City*</p>
                    <input class="border-[#76b5c5] border-2 rounded-lg h-[60px] focus:outline-none px-4 py-2 caret-[#76b5c5b4] text-[#2C3E50] focus:ring-0"/>
                </div>
                <div class="w-full flex flex-col">
                    <p class="text-[#2C3E50] text-xl font-poppins font-light">Street Name*</p>
                    <input class="border-[#76b5c5] border-2 rounded-lg h-[60px] focus:outline-none focus:ring-0 px-4 py-2 caret-[#76b5c5b4] text-[#2C3E50]"/>
                </div>
                <div class="w-full flex justify-between gap-5">
                    <div class="w-full flex flex-col">
                        <p class="text-[#2C3E50] text-xl font-poppins font-light">Street Number*</p>
                        <input class="border-[#76b5c5] border-2 rounded-lg h-[60px] focus:outline-none focus:ring-0 px-4 py-2 caret-[#76b5c5b4] text-[#2C3E50]"/>
                    </div>
                    <div class="w-full flex flex-col">
                        <p class="text-[#2C3E50] text-xl font-poppins font-light">Zip*</p>
                        <input class="border-[#76b5c5] border-2 rounded-lg h-[60px] focus:outline-none px-4 py-2 caret-[#76b5c5b4] text-[#2C3E50] focus:ring-0"/>
                    </div>
                </div>
                <div class="w-full flex justify-center gap-3">
                    <button onclick="flipCardBack()" class="w-1/3 h-[60px] border-[#76b5c5] border-2 flex items-center justify-center rounded gap-3 transition-all duration-300 hover:scale-[1.05]">
                        <p class="text-[#76b5c5] tracking-wide font-poppins text-3xl p-0 m-0">Back</p>
                    </button>
                    <button onclick="flipCardBack()" class="w-1/3 h-[60px] bg-[#76b5c5] flex items-center justify-center rounded gap-3 transition-all duration-300 hover:scale-[1.05]">
                        <p class="text-white tracking-wide font-poppins text-3xl p-0 m-0">Sign Up</p>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>