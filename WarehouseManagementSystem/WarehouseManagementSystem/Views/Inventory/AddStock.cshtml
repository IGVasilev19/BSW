@{
    ViewData["Title"] = "AddStock";
}
@using WarehouseManagementSystem.Models
@model InventoryViewModel


<div class="w-full h-full flex bg-white">
    @Html.Partial("_Sidebar", "Inventory")
    <div class="w-full h-full flex flex-col items-center justify-center gap-3">
        <p class="select-none text-[#2C3E50] text-6xl font-poppins font-bold text-center">Add Stock</p>
        <form method="post" asp-action="AddStock" asp-controller="Inventory" class="w-[70%] flex flex-col items-center justify-center gap-3">
            @Html.AntiForgeryToken()
            <div class="w-full flex flex-col">
                <div class="flex gap-3">
                    <p class="select-none text-[#2C3E50] text-xl font-poppins font-light">Product*</p>
                </div>
                <div class="border-[#76b5c5] border-2 rounded-lg h-[60px] focus:outline-none focus:ring-0 px-4 py-2 caret-[#76b5c5b4] text-[#2C3E50] flex items-center">@Model.ProductName</div>
            </div>
            <div class="w-full flex flex-col">
                <div class="flex gap-3">
                    <p class="select-none text-[#2C3E50] text-xl font-poppins font-light">Category*</p>
                </div>
                <div class="border-[#76b5c5] border-2 rounded-lg h-[60px] focus:outline-none focus:ring-0 px-4 py-2 caret-[#76b5c5b4] text-[#2C3E50] flex items-center">@Model.Category</div>
            </div>
            <div class="w-full flex flex-col">
                <div class="flex gap-3">
                    <p class="select-none text-[#2C3E50] text-xl font-poppins font-light">Zone*</p>
                </div>
                <div class="border-[#76b5c5] border-2 rounded-lg h-[60px] focus:outline-none focus:ring-0 px-4 py-2 caret-[#76b5c5b4] text-[#2C3E50] flex items-center">@Model.ZoneName</div>
            </div>
            <div class="w-full flex flex-col">
                <div class="flex gap-3">
                    <p class="select-none text-[#2C3E50] text-xl font-poppins font-light">Price*</p>
                </div>
                <div class="border-[#76b5c5] border-2 rounded-lg h-[60px] focus:outline-none focus:ring-0 px-4 py-2 caret-[#76b5c5b4] text-[#2C3E50] flex items-center" >@Model.ProductPrice</div>
            </div>
            <div class="w-full flex flex-col">
                <div class="flex gap-3">
                    <p class="select-none text-[#2C3E50] text-xl font-poppins font-light">Quantity*</p>
                </div>
                <input asp-for="Quantity" placeholder="@Model.Quantity" type="number" class="border-[#76b5c5] border-2 rounded-lg h-[60px] focus:outline-none focus:ring-0 px-4 py-2 caret-[#76b5c5b4] text-[#2C3E50]" />
            </div>
            <input type="hidden" asp-for="InventoryId" name="InventoryId"/>
            <button type="submit" class="w-1/3 h-[60px] bg-[#76b5c5] flex items-center justify-center rounded gap-3 transition-all duration-300 hover:scale-[1.05]">
                <p class="text-white tracking-wide font-poppins text-3xl p-0 m-0">SAVE</p>
            </button>
        </form>
    </div>
</div>